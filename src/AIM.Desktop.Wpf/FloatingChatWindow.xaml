<Window x:Class="AIM.Desktop.Wpf.FloatingChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIM.Desktop.Wpf.Views"
        Title="{Binding WindowTitle}"
        Width="560"
        Height="620"
        MinWidth="420"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AimBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <DockPanel LastChildFill="True">
                <CheckBox x:Name="TopmostToggle"
                          DockPanel.Dock="Right"
                          Content="Topmost"
                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Topmost, Mode=TwoWay}"
                          VerticalAlignment="Center" />
                <TextBlock Text="{Binding WindowTitle}"
                           Foreground="{StaticResource AimTextBrush}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <views:ChatSurface Grid.Row="1" />
    </Grid>
</Window>
