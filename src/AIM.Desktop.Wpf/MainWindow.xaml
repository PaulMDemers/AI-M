<Window x:Class="AIM.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AIM.Desktop.Wpf.Converters"
        xmlns:views="clr-namespace:AIM.Desktop.Wpf.Views"
        Title="AI-M"
        Height="760"
        Width="280"
        MinHeight="560"
        MinWidth="260"
        Background="{StaticResource AimBackgroundBrush}">
    <Window.Resources>
        <converters:BooleanToGridLengthConverter x:Key="BooleanToGridLengthConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BrushConverter x:Key="BrushConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsAllInOneMode, Converter={StaticResource BooleanToGridLengthConverter}, ConverterParameter=Contacts}" />
            <ColumnDefinition Width="{Binding IsAllInOneMode, Converter={StaticResource BooleanToGridLengthConverter}}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="12,14,12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Menu Background="Transparent"
                          Padding="0"
                          Margin="0,0,0,8">
                        <MenuItem Header="_Window">
                            <MenuItem Header="{Binding ShellModeButtonText}"
                                      Command="{Binding ToggleAllInOneModeCommand}" />
                            <Separator />
                            <MenuItem Header="_Check Providers"
                                      Command="{Binding CheckProvidersCommand}" />
                            <MenuItem Header="{Binding PendingActionsMenuText}"
                                      Command="{Binding OpenPendingActionsCommand}" />
                            <MenuItem Header="_Settings"
                                      Command="{Binding OpenProviderSettingsCommand}" />
                        </MenuItem>
                    </Menu>
                    <Border Background="{StaticResource AimAccentBrush}"
                            Grid.Row="1"
                            Padding="10,8"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="AI-M"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />
                            <TextBlock Text="AI Messenger"
                                       Foreground="#DDEEEE"
                                       FontSize="11" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        BorderBrush="{StaticResource AimBorderBrush}"
                        BorderThickness="0,1,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="12,8,12,6">
                            <TextBlock Text="Contacts"
                                       Foreground="{StaticResource AimTextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="12" />
                            <TextBlock Text="{Binding ProviderSummary}"
                                       Margin="0,2,0,0"
                                       Foreground="{StaticResource AimSubtleTextBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap" />
                            <Button Margin="0,6,0,0"
                                    Padding="7,4"
                                    MinHeight="0"
                                    Background="#FFF7D1"
                                    BorderBrush="#C49A00"
                                    BorderThickness="1"
                                    Foreground="{StaticResource AimTextBrush}"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding OpenPendingActionsCommand}"
                                    ToolTip="Review pending AI actions"
                                    Visibility="{Binding HasPendingActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DockPanel LastChildFill="True">
                                    <Border Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Top"
                                            Background="#D97706"
                                            CornerRadius="8">
                                        <TextBlock Text="!"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding PendingActionsStatusText}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                            </Button>
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 MouseDoubleClick="FriendsList_MouseDoubleClick"
                                 ItemsSource="{Binding FriendsView}"
                                 SelectedItem="{Binding SelectedFriend, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True"
                                                                  Margin="0,2,0,0">
                                                            <Expander.Header>
                                                                <DockPanel LastChildFill="False">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="{StaticResource AimTextBrush}"
                                                                               FontSize="11"
                                                                               FontWeight="Bold" />
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat= ({0})}"
                                                                               Foreground="{StaticResource AimSubtleTextBrush}"
                                                                               FontSize="11"
                                                                               Margin="2,0,0,0" />
                                                                </DockPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2" MinHeight="44">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="24"
                                                Height="24"
                                                CornerRadius="5"
                                                Background="{StaticResource AimAccentBrush}"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding PresenceDetail}">
                                            <Grid ClipToBounds="True">
                                                <TextBlock Text="{Binding AvatarText}"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Image Source="{Binding AvatarImageUri}"
                                                       Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvatarImageUri}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                        </Border>
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Grid.Column="0"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Margin="0,0,4,7"
                                                 Stroke="White"
                                                 StrokeThickness="1"
                                                 Fill="{Binding PresenceBrush, Converter={StaticResource BrushConverter}}"
                                                 ToolTip="{Binding PresenceDetail}" />

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="4,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource AimTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="{StaticResource AimSubtleTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding PresenceLabel}"
                                                       Foreground="{Binding PresenceBrush, Converter={StaticResource BrushConverter}}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       ToolTip="{Binding PresenceDetail}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="10">
                    <StackPanel>
                        <Button Content="Add Contact"
                                Margin="0,0,0,6"
                                ToolTip="Add AI contact"
                                Command="{Binding AddPersonalityCommand}" />
                        <UniformGrid Columns="2">
                            <Button Margin="0,0,3,0"
                                    Content="Edit"
                                    Command="{Binding EditPersonalityCommand}" />
                            <Button Margin="3,0,0,0"
                                    Content="Memory"
                                    Command="{Binding ReviewMemoryCommand}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Visibility="{Binding IsAllInOneMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Content="{Binding CurrentChat}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <views:ChatSurface />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
