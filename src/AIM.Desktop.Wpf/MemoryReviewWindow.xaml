<Window x:Class="AIM.Desktop.Wpf.MemoryReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="600"
        Height="480"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AimBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AimTextBrush}" />

        <ListBox Grid.Row="1"
                 Margin="0,16,0,16"
                 ItemsSource="{Binding Suggestions}"
                 SelectedItem="{Binding SelectedSuggestion}"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="6">
                        <TextBlock Text="{Binding Content}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource AimTextBrush}" />
                        <TextBlock Text="{Binding CreatedAt}"
                                   FontSize="11"
                                   Foreground="{StaticResource AimSubtleTextBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Width="92"
                    Margin="0,0,8,0"
                    Content="Approve"
                    Command="{Binding ApproveCommand}" />
            <Button Grid.Column="2"
                    Width="92"
                    Margin="0,0,8,0"
                    Content="Reject"
                    Command="{Binding RejectCommand}" />
            <Button Grid.Column="3"
                    Width="92"
                    Content="Close"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
