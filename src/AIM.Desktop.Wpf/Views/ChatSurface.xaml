<UserControl x:Class="AIM.Desktop.Wpf.Views.ChatSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AIM.Desktop.Wpf.Converters">
    <UserControl.Resources>
        <converters:BrushConverter x:Key="BrushConverter" />
        <converters:HorizontalAlignmentConverter x:Key="HorizontalAlignmentConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="MessageBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="MaxWidth" Value="560" />
            <Setter Property="Background" Value="{Binding BubbleBackground, Converter={StaticResource BrushConverter}}" />
            <Setter Property="HorizontalAlignment" Value="{Binding HorizontalAlignment, Converter={StaticResource HorizontalAlignmentConverter}}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AimBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="42"
                        Height="42"
                        Margin="0,0,12,0"
                        Background="{StaticResource AimAccentBrush}"
                        CornerRadius="8">
                    <Grid ClipToBounds="True">
                        <TextBlock Text="{Binding Personality.AvatarText}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Image Source="{Binding AvatarImageUri}"
                               Stretch="UniformToFill">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AvatarImageUri}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Personality.DisplayName}"
                               Foreground="{StaticResource AimTextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="{Binding Personality.Status}"
                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                   FontSize="12" />
                        <TextBlock Text="  /  "
                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding ConversationTitle}"
                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </StackPanel>
                <Expander Grid.Column="2"
                          Width="250"
                          Header="Conversations"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top">
                    <Border Margin="0,8,0,0"
                            Padding="10"
                            Background="{StaticResource AimBackgroundBrush}"
                            BorderBrush="{StaticResource AimBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ComboBox ItemsSource="{Binding ConversationGroups}"
                                      SelectedItem="{Binding SelectedConversationGroup}"
                                      DisplayMemberPath="Title"
                                      MinHeight="30" />
                            <TextBox Grid.Row="1"
                                     Margin="0,6,0,0"
                                     Text="{Binding ConversationGroupTitle, UpdateSourceTrigger=PropertyChanged}" />
                            <UniformGrid Grid.Row="2"
                                         Columns="3"
                                         Margin="0,6,0,10">
                                <Button Content="+"
                                        Margin="0,0,4,0"
                                        ToolTip="New group"
                                        Command="{Binding NewConversationGroupCommand}" />
                                <Button Content="Save"
                                        Margin="4,0,4,0"
                                        Command="{Binding RenameConversationGroupCommand}" />
                                <Button Content="Archive"
                                        Margin="4,0,0,0"
                                        Command="{Binding ArchiveConversationGroupCommand}" />
                            </UniformGrid>

                            <ComboBox Grid.Row="3"
                                      ItemsSource="{Binding Conversations}"
                                      SelectedItem="{Binding SelectedConversation}"
                                      DisplayMemberPath="Title"
                                      MinHeight="30" />
                            <TextBox Grid.Row="4"
                                     Margin="0,6,0,0"
                                     Text="{Binding ConversationTitle, UpdateSourceTrigger=PropertyChanged}" />
                            <UniformGrid Grid.Row="5"
                                         Columns="3"
                                         Margin="0,6,0,0">
                                <Button Content="+"
                                        Margin="0,0,4,0"
                                        ToolTip="New conversation"
                                        Command="{Binding NewConversationCommand}" />
                                <Button Content="Save"
                                        Margin="4,0,4,0"
                                        Command="{Binding RenameConversationCommand}" />
                                <Button Content="Archive"
                                        Margin="4,0,0,0"
                                        Command="{Binding ArchiveConversationCommand}" />
                            </UniformGrid>

                            <DockPanel Grid.Row="6"
                                       Margin="0,12,0,0"
                                       LastChildFill="False">
                                <TextBlock Text="Summary"
                                           Foreground="{StaticResource AimTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ConversationSummaryUpdatedAtLabel}"
                                           Margin="8,0,0,0"
                                           Foreground="{StaticResource AimSubtleTextBrush}"
                                           FontSize="11" />
                            </DockPanel>
                            <TextBox Grid.Row="7"
                                     Margin="0,6,0,0"
                                     MinHeight="70"
                                     MaxHeight="120"
                                     Text="{Binding ConversationSummary, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                            <UniformGrid Grid.Row="8"
                                         Columns="2"
                                         Margin="0,6,0,0">
                                <Button Content="Save"
                                        Margin="0,0,4,0"
                                        Command="{Binding SaveConversationSummaryCommand}" />
                                <Button Content="Refresh"
                                        Margin="4,0,0,0"
                                        Command="{Binding RefreshConversationSummaryCommand}" />
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Expander>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFF8E5"
                BorderBrush="#E4B463"
                BorderThickness="0,0,0,1"
                Padding="14,10"
                Visibility="{Binding HasProviderSetupIssue, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ProviderSetupMessage}"
                           Foreground="{Binding ProviderSetupBrush, Converter={StaticResource BrushConverter}}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Grid.Column="1"
                        MinWidth="110"
                        Content="Setup Provider"
                        Command="{Binding OpenProviderSettingsCommand}" />
            </Grid>
        </Border>

        <ScrollViewer x:Name="MessagesScrollViewer"
                      Grid.Row="2"
                      Padding="18"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource MessageBubbleStyle}">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding RoleLabel}"
                                               Foreground="{StaticResource AimSubtleTextBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CreatedAtLabel}"
                                               Margin="8,0,0,0"
                                               Foreground="{StaticResource AimSubtleTextBrush}"
                                               FontSize="11" />
                                </DockPanel>
                                <TextBlock Text="{Binding Content}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource AimTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,8"
                Visibility="{Binding HasPendingAgentActions, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Expander Header="{Binding PendingAgentActionHeader}"
                      IsExpanded="True">
                <ItemsControl ItemsSource="{Binding PendingAgentActions}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6"
                                    Padding="10"
                                    Background="{StaticResource AimBackgroundBrush}"
                                    BorderBrush="{StaticResource AimBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource AimTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CreatedAtLabel}"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource AimSubtleTextBrush}"
                                                       FontSize="11" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Detail}"
                                                   Margin="0,4,12,0"
                                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Approve"
                                                MinWidth="72"
                                                Margin="8,0,0,0"
                                                Command="{Binding DataContext.ApprovePendingAgentActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Deny"
                                                MinWidth="56"
                                                Margin="6,0,0,0"
                                                Command="{Binding DataContext.DenyPendingAgentActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </Border>

        <Border Grid.Row="4"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,8"
                Visibility="{Binding HasToolTraces, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Expander Header="{Binding ToolTraceHeader}">
                <ScrollViewer MaxHeight="170"
                              Margin="0,8,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ToolTraces}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="8"
                                        Background="{StaticResource AimBackgroundBrush}"
                                        BorderBrush="{StaticResource AimBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}"
                                                   Foreground="{StaticResource AimTextBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Arguments}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Result}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Expander>
        </Border>

        <Border Grid.Row="5"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="MessageInput"
                             Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="42"
                             MaxHeight="120"
                             Margin="0,0,10,0"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="MessageInput_KeyDown" />
                    <DockPanel Grid.Row="1"
                               Margin="2,6,0,0"
                               LastChildFill="False">
                        <TextBlock Text="{Binding BusyText}"
                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <Button Content="Stop"
                                Margin="8,0,0,0"
                                MinHeight="0"
                                Height="22"
                                Padding="8,0"
                                FontSize="11"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Command="{Binding CancelResponseCommand}" />
                    </DockPanel>
                </Grid>
                <Button Grid.Column="1"
                        Width="86"
                        Content="Send"
                        Command="{Binding SendMessageCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
