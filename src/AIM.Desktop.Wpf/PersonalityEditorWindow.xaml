<Window x:Class="AIM.Desktop.Wpf.PersonalityEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Contact"
        Width="760"
        Height="660"
        MinWidth="640"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AimBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="AI Contact"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AimTextBrush}" />

        <TabControl Grid.Row="1" Margin="0,16,0,16">
            <TabItem Header="Templates">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ListBox ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4" MinHeight="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30"
                                            Height="30"
                                            CornerRadius="5"
                                            Background="{StaticResource AimAccentBrush}"
                                            VerticalAlignment="Center">
                                        <Grid ClipToBounds="True">
                                            <TextBlock Text="{Binding AvatarText}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{Binding AvatarImageUri}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AvatarImageUri}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource AimTextBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="{StaticResource AimSubtleTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Column="1" Margin="16,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel LastChildFill="True">
                            <Border Width="54"
                                    Height="54"
                                    Margin="0,0,12,0"
                                    CornerRadius="8"
                                    Background="{StaticResource AimAccentBrush}">
                                <Grid ClipToBounds="True">
                                    <TextBlock Text="{Binding SelectedTemplate.AvatarText}"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <Image Source="{Binding SelectedTemplate.AvatarImageUri}"
                                           Stretch="UniformToFill">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTemplate.AvatarImageUri}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedTemplate.DisplayName}"
                                           Foreground="{StaticResource AimTextBrush}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedTemplate.Category}"
                                           Foreground="{StaticResource AimSubtleTextBrush}"
                                           FontSize="12" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,12"
                                   Text="{Binding SelectedTemplate.Description}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource AimTextBrush}" />

                        <TextBox Grid.Row="2"
                                 Text="{Binding SelectedTemplate.SystemPrompt, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />

                        <Button Grid.Row="3"
                                Width="130"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Content="Apply"
                                Command="{Binding ApplyTemplateCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Details">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Name" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Text="Status" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Text="Avatar" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             MaxLength="1"
                             Text="{Binding AvatarText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Text="Provider" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider}"
                                  DisplayMemberPath="DisplayName"
                                  MinHeight="34" />
                        <TextBox Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Text="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <TextBlock Grid.Row="4" Text="Group" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="5" Text="Avatar image" Margin="0,10,0,0" VerticalAlignment="Center" />
                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             Text="{Binding AvatarImagePath, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="6" Text="Prompt" Margin="0,10,0,0" />
                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </TabItem>

            <TabItem Header="Memory">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Memories}"
                             SelectedItem="{Binding SelectedMemory}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AimTextBrush}" />
                                    <TextBlock Text="{Binding CreatedAt}"
                                               FontSize="11"
                                               Foreground="{StaticResource AimSubtleTextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewMemoryText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="80"
                                Margin="8,0,0,0"
                                Content="Add"
                                Command="{Binding AddMemoryCommand}" />
                        <Button Grid.Column="2"
                                Width="80"
                                Margin="8,0,0,0"
                                Content="Delete"
                                Command="{Binding DeleteMemoryCommand}" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Width="90"
                    Content="Delete"
                    Command="{Binding DeleteCommand}" />
            <Button Grid.Column="2"
                    Width="90"
                    Margin="0,0,8,0"
                    Content="Save"
                    Command="{Binding SaveCommand}" />
            <Button Grid.Column="3"
                    Width="90"
                    Content="Close"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
