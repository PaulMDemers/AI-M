<Window x:Class="AIM.Desktop.Wpf.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AIM.Desktop.Wpf.Converters"
        Title="AI-M Setup"
        Width="560"
        Height="520"
        MinWidth="520"
        MinHeight="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AimBackgroundBrush}">
    <Window.Resources>
        <converters:BrushConverter x:Key="BrushConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Welcome to AI-M"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AimTextBrush}" />
            <TextBlock Text="Choose one provider to bring your AI contacts online."
                       Margin="0,4,0,0"
                       Foreground="{StaticResource AimSubtleTextBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TabControl Grid.Row="1"
                    Margin="0,16,0,16"
                    SelectedIndex="{Binding SelectedProviderIndex, Mode=TwoWay}">
            <TabItem Header="OpenAI">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            Padding="10,8"
                            Margin="0,0,0,14"
                            BorderBrush="{StaticResource AimBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource AimBackgroundBrush}">
                        <TextBlock Text="{Binding OpenAiStatus}"
                                   Foreground="{Binding OpenAiStatusBrush, Converter={StaticResource BrushConverter}}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="API Key"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Text="Model"
                               Margin="0,12,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,12,0,0"
                             Text="{Binding OpenAiModelId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </TabItem>

            <TabItem Header="Ollama">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            Padding="10,8"
                            Margin="0,0,0,14"
                            BorderBrush="{StaticResource AimBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource AimBackgroundBrush}">
                        <TextBlock Text="{Binding OllamaStatus}"
                                   Foreground="{Binding OllamaStatusBrush, Converter={StaticResource BrushConverter}}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Endpoint"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding OllamaEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Text="Model"
                               Margin="0,12,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,12,0,0"
                             Text="{Binding OllamaModelId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </TabItem>

            <TabItem Header="Bedrock">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            Padding="10,8"
                            Margin="0,0,0,14"
                            BorderBrush="{StaticResource AimBorderBrush}"
                            BorderThickness="1"
                            Background="{StaticResource AimBackgroundBrush}">
                        <TextBlock Text="{Binding BedrockStatus}"
                                   Foreground="{Binding BedrockStatusBrush, Converter={StaticResource BrushConverter}}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="Region"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Text="{Binding BedrockRegion, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2"
                               Text="Model"
                               Margin="0,12,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AimTextBrush}" />
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,12,0,0"
                             Text="{Binding BedrockModelId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding Status}"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource AimSubtleTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,12,0" />
            <Button Grid.Column="1"
                    MinWidth="130"
                    Margin="0,0,8,0"
                    Content="Continue Demo"
                    Command="{Binding ContinueWithDemoCommand}" />
            <Button Grid.Column="2"
                    MinWidth="150"
                    Content="Save and Continue"
                    Command="{Binding SaveSelectedProviderCommand}" />
        </Grid>
    </Grid>
</Window>
