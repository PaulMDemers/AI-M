<Window x:Class="AIM.Desktop.Wpf.PendingActionsReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pending AI Actions"
        Width="620"
        Height="460"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AimBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Pending AI Actions"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AimTextBrush}" />
            <TextBlock Text="{Binding Header}"
                       Margin="0,4,0,0"
                       Foreground="{StaticResource AimSubtleTextBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Background="{StaticResource AimPanelBrush}"
                BorderBrush="{StaticResource AimBorderBrush}"
                BorderThickness="1">
            <Grid>
                <TextBlock Text="No pending actions."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AimSubtleTextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasActions}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Actions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8"
                                        Padding="10"
                                        Background="{StaticResource AimBackgroundBrush}"
                                        BorderBrush="{StaticResource AimBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource AimTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       Margin="0,3,0,0"
                                                       Foreground="{StaticResource AimSubtleTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Margin="0,8,12,0"
                                                       Foreground="{StaticResource AimTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ApprovalUnavailableText}"
                                                       Margin="0,8,12,0"
                                                       Foreground="#D97706"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasApprovalNote}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Content="Approve"
                                                    MinWidth="78"
                                                    Margin="8,0,0,0"
                                                    IsEnabled="{Binding CanApprove}"
                                                    Command="{Binding DataContext.ApproveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Deny"
                                                    MinWidth="62"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding DataContext.DenyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Width="90"
                HorizontalAlignment="Right"
                Content="Close"
                Click="CloseButton_Click" />
    </Grid>
</Window>
